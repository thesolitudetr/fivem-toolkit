{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dexta Toolkit",
  "version": "0.1.5",
  "identifier": "com.dexta.toolkit",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Dexta Toolkit",
        "width": 1180,
        "height": 760,
        "minWidth": 1024,
        "minHeight": 640,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "bin/*"
    ]
  }
}